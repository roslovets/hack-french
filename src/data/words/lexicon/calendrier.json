        "ru": "праздничный (нерабочий) день"
      },
      {
        "fr": "deux fois par jour",
        "ru": "два раза в день"
      }
    ],
    "contrastPairs": [
      {
        "with": "journée",
        "note": "jour — день как точка/единица счёта (trois jours); journée — день как длительность и его наполнение (bonne journée, toute la journée)."
      },
      {
        "with": "semaine",
        "note": "jour — день; semaine — неделя (sept jours). Не путать единицы: par jour ≠ par semaine."
      }
    ],
    "frequencyRank": 90,
    "level": "A1",
    "tags": ["calendrier", "temps"],
    "caseIds": ["wc-calendrier"],
