    "pos": "noun",
    "gender": "m",
    "ipa": "/ʒuʁ/",
    "translationsRu": ["день", "сутки"],
    "translationsEn": ["day"],
    "semanticCore": "День как единица счёта времени и как светлое время суток; считают именно в jours.",
    "collocations": [
      {
        "fr": "tous les jours",
        "ru": "каждый день"
      },
      {
        "fr": "quel jour sommes-nous ?",
        "ru": "какой сегодня день (недели)?"
      },
      {
