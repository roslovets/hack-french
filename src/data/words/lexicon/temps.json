    "contrastPairs": [
      {
        "with": "encore",
        "note": "В значении «всё ещё» toujours и encore близки (il dort toujours = il dort encore), но toujours — это ещё и «всегда» (привычка), а encore — «ещё раз / добавка»."
      },
      {
        "with": "jamais",
        "note": "Прямая пара: toujours = всегда; jamais = никогда. Противоположности на шкале частоты."
      }
    ],
    "frequencyRank": 70,
    "level": "A2",
    "tags": ["temps", "fréquence", "adverbe"],
