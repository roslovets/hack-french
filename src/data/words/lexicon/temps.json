  {
    "id": "wl-temps-jamais",
    "lemma": "jamais",
    "pos": "adv",
    "ipa": "/ʒa.mɛ/",
    "translationsRu": ["никогда", "когда-либо"],
    "translationsEn": ["never", "ever"],
    "semanticCore": "Ноль раз на шкале частоты («никогда», с ne); в вопросе и после si — «когда-либо».",
    "collocations": [
      {
        "fr": "ne… jamais",
        "ru": "никогда"
      },
      {
        "fr": "jamais de la vie",
        "ru": "ни за что на свете"
      },
      {
        "fr": "plus jamais",
        "ru": "больше никогда"
      },
      {
        "fr": "à jamais",
        "ru": "навсегда"
      }
    ],
    "contrastPairs": [
      {
        "with": "toujours",
        "note": "jamais = никогда (с ne: Je ne fume jamais); toujours = всегда. Противоположные концы шкалы."
      },
      {
        "with": "déjà",
        "note": "В вопросе они спорят: Tu as déjà vu ça ? = «ты уже это видел?»; As-tu jamais vu ça ? = «видел ли ты это когда-либо?». jamais тут = «когда-либо», не «никогда»."
      }
    ],
    "frequencyRank": 130,
    "level": "A2",
    "tags": ["temps", "fréquence", "négation", "adverbe"],
