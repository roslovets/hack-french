[
  {
    "id": "wl-temps-deja",
    "lemma": "déjà",
    "pos": "adv",
    "ipa": "/de.ʒa/",
    "translationsRu": ["уже", "когда-то раньше"],
    "translationsEn": ["already", "before", "yet"],
    "semanticCore": "Действие случилось раньше ожидаемого момента — «уже».",
    "collocations": [
      {
        "fr": "C'est déjà fini.",
        "ru": "Это уже закончилось."
      },
      {
        "fr": "J'ai déjà mangé.",
        "ru": "Я уже поел."
      },
      {
        "fr": "Il est déjà tard.",
        "ru": "Уже поздно."
      },
      {
        "fr": "Tu es déjà là ?",
        "ru": "Ты уже здесь?"
      }
    ],
    "contrastPairs": [
      {
        "with": "encore",
        "note": "déjà = уже (раньше срока); encore = ещё / всё ещё. «Уже сделал» — déjà; «ещё не сделал» — pas encore."
      },
      {
        "with": "maintenant",
        "note": "déjà = уже (раньше, чем думали); maintenant = сейчас (в данный момент). «Уже поздно» ≠ «сейчас поздно»."
      }
    ],
    "frequencyRank": 110,
    "level": "A2",
    "tags": ["temps", "adverbe"],
    "caseIds": ["wc-temps"]
  },
  {
