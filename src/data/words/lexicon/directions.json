  {
    "id": "wl-directions-ici",
    "lemma": "ici",
    "pos": "adv",
    "ipa": "/i.si/",
    "translationsRu": ["здесь", "тут", "сюда"],
    "translationsEn": ["here"],
    "semanticCore": "Место рядом с говорящим: «здесь», там, где я; «сюда» при движении ко мне.",
    "collocations": [
      {
        "fr": "viens ici",
        "ru": "иди сюда"
      },
      {
        "fr": "par ici",
        "ru": "сюда / в эту сторону"
      },
      {
        "fr": "ici, c'est la cuisine",
        "ru": "вот тут кухня"
      },
      {
        "fr": "d'ici à la gare",
        "ru": "отсюда до вокзала"
      }
    ],
    "contrastPairs": [
      {
        "with": "là",
        "note": "ici = здесь (рядом со мной); là = там (дальше) или просто «вот тут». В разговоре là часто вытесняет ici."
      },
      {
        "with": "voici",
        "note": "ici = «здесь» (место); voici = «вот» (представляя предмет/человека: voici mon ami). Общий корень, но разные роли."
      }
    ],
    "frequencyRank": 220,
    "level": "A2",
    "tags": ["directions", "position"],
    "caseIds": ["wc-directions"],
    "audio": {
      "isolated": "audio/wl-directions-ici.mp3"
    }
  },
  {
    "id": "wl-directions-la",
    "lemma": "là",
    "pos": "adv",
    "ipa": "/la/",
    "translationsRu": ["там", "вот тут"],
    "translationsEn": ["there"],
    "semanticCore": "Указание на место не у самого говорящего — «там»; в разговоре часто просто «тут/здесь» вместо ici.",
    "collocations": [
      {
        "fr": "là-bas",
        "ru": "вон там (далеко)"
      },
      {
        "fr": "il est là",
        "ru": "он здесь / на месте"
      },
      {
        "fr": "mets-le là",
        "ru": "положи это туда / вот сюда"
      },
      {
        "fr": "là, à droite",
        "ru": "вон там, справа"
      }
    ],
    "contrastPairs": [
      {
        "with": "ici",
        "note": "là = там (дальше) или нейтральное «тут»; ici = строго «здесь, у меня». «Il est là» обычно значит «он на месте», а не «вон там»."
      },
      {
        "with": "la (артикль)",
        "note": "là (с accent grave) — наречие «там»; la (без акцента) — артикль ж.р. «la maison». Произношение одинаковое /la/, различает только акцент и роль."
      }
    ],
    "frequencyRank": 120,
    "level": "A2",
    "tags": ["directions", "position"],
    "caseIds": ["wc-directions"],
    "audio": {
      "isolated": "audio/wl-directions-la.mp3"
    }
  },
