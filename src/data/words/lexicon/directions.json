[
  {
    "id": "wl-directions-gauche",
    "lemma": "gauche",
    "pos": "noun",
    "gender": "f",
    "ipa": "/ɡoʃ/",
    "translationsRu": ["лево", "левая сторона"],
    "translationsEn": ["left"],
    "semanticCore": "Левая сторона; в указаниях пути почти всегда в связке «à gauche» — налево / слева.",
    "collocations": [
      {
        "fr": "à gauche",
        "ru": "налево / слева"
      },
      {
        "fr": "tournez à gauche",
        "ru": "поверните налево"
      },
      {
        "fr": "sur votre gauche",
        "ru": "по левую руку от вас"
      },
      {
        "fr": "la première à gauche",
        "ru": "первая (улица) налево"
      }
    ],
    "contrastPairs": [
      {
        "with": "droite",
        "note": "gauche = лево; droite = право. Это пара противоположностей — путать их в указаниях пути критично."
      },
      {
        "with": "gauche (прил.)",
        "note": "То же слово как прилагательное значит «неуклюжий» (un geste gauche). В навигации это всегда «левый/налево»."
      }
    ],
    "frequencyRank": 620,
    "level": "A2",
    "tags": ["directions", "orientation"],
    "caseIds": ["wc-directions"],
    "audio": {
      "isolated": "audio/wl-directions-gauche.mp3"
    }
  },
  {
