    "ipa": "/œʁ/",
    "translationsRu": ["час", "время (который час)"],
    "translationsEn": ["hour", "time (o'clock)"],
    "semanticCore": "И единица времени (60 минут), и «время» в вопросе «который час»: une heure = и «один час», и «час дня».",
    "collocations": [
      {
        "fr": "Quelle heure est-il ?",
        "ru": "Который час?"
      },
      {
        "fr": "Il est deux heures.",
        "ru": "Сейчас два часа."
      },
      {
        "fr": "à l'heure",
        "ru": "вовремя; в час (за час)"
      },
      {
        "fr": "une demi-heure",
        "ru": "полчаса"
      }
    ],
    "contrastPairs": [
      {
        "with": "temps",
        "note": "heure = час / время на часах (который час); temps = время вообще (как ресурс) и погода. «Сколько времени?» в смысле часов — Quelle heure est-il ?, а не combien de temps."
      },
      {
        "with": "fois",
        "note": "heure = час (длительность/время на часах); fois = раз (количество повторов). «Два часа» — deux heures, «два раза» — deux fois."
      }
    ],
    "frequencyRank": 90,
